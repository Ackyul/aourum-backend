# Cloudinary — consigue estos valores en https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Puerto del servidor (opcional, default 5000)
PORT=5000

# Supabase — consigue estos valores en https://supabase.com/dashboard
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_supabase_key

# JWT — REQUERIDO. Genera un secreto fuerte con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_aqui

# URL del frontend para CORS (requerido en producción)
FRONTEND_URL=http://localhost:3000

# Resend — consigue estos valores en https://resend.com/
# RESEND_API_KEY es requerida para el envío real de correos de recuperación de contraseña.
# EMAIL_FROM define el remitente (requiere verificar tu dominio en Resend).
RESEND_API_KEY=tu_resend_api_key
EMAIL_FROM=AOURUM <no-reply@tudominio.com>

# PhotoRoom — consigue estos valores en https://www.photoroom.com/api
PHOTOROOM_API_KEY=tu_photoroom_api_key

# Google OAuth — consigue estos valores en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu_google_client_id

# Facebook OAuth — consigue estos valores en https://developers.facebook.com/
FACEBOOK_APP_ID=tu_facebook_app_id
FACEBOOK_APP_SECRET=tu_facebook_app_secret
